{
  "name": "waymaker-ticker",
  "version": "0.1.0",
  "private": true,
  "description": "The 25 Initiative impact dashboard for Waymaker.Church.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "electron": "npm run build && electron .",
    "dist:mac": "npm run build && electron-builder --mac dmg zip"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "church.waymaker.the25initiative",
    "productName": "The 25 Initiative",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
